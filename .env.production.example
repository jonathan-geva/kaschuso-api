# Production environment template for kaschuso-api
# Copy this file to .env and fill in secure values.

NODE_ENV=production
PORT=3001

# Keep default unless upstream host changes.
KASCHUSO_BASE_URL=https://kaschuso.so.ch/

# Required: exact frontend origin allowed by CORS.
FRONTEND_ORIGIN=https://app.example.com

# Required: strong random secret for JWT signing.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-secret

# Session/token lifetime in seconds (15 minutes default).
API_SESSION_TTL_SECONDS=900

# Global rate limit per client IP.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120

# Authentication rate limit per client IP.
API_AUTH_RATE_LIMIT_WINDOW_MS=300000
API_AUTH_RATE_LIMIT_MAX=10
